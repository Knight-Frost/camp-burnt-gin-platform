{
  "name": "camp-burnt-gin-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\"",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "a11y": "npm run build && npm run a11y:lighthouse && npm run a11y:axe",
    "a11y:lighthouse": "lighthouse http://localhost:4173 --preset=desktop --output=html --output-path=./lighthouse-report.html --chrome-flags=\"--headless\" --quiet",
    "a11y:axe": "start-server-and-test preview http://localhost:4173 'axe http://localhost:4173 --exit'",
    "a11y:dev": "axe http://localhost:5173",
    "analyze": "npm run build && open dist/stats.html",
    "perf": "npm run build && npm run preview & sleep 3 && npm run a11y:lighthouse"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@radix-ui/react-accordion": "^1.2.4",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-select": "^2.2.1",
    "@reduxjs/toolkit": "^2.5.0",
    "axios": "^1.7.9",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "framer-motion": "^12.4.0",
    "i18next": "^25.8.13",
    "lucide-react": "^0.487.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.54.2",
    "react-i18next": "^16.5.4",
    "react-redux": "^9.1.2",
    "react-router-dom": "^7.0.1",
    "recharts": "^3.7.0",
    "redux-persist": "^6.0.0",
    "sonner": "^2.0.0",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.11.1",
    "@axe-core/react": "^4.11.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^3.0.5",
    "autoprefixer": "^10.4.20",
    "axe-core": "^4.11.1",
    "eslint": "^9.18.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^17.3.0",
    "jsdom": "^25.0.1",
    "lighthouse": "^13.0.3",
    "madge": "^8.0.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "rollup-plugin-visualizer": "^6.0.5",
    "start-server-and-test": "^2.1.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.7.2",
    "vite": "^5.4.21",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^3.0.5"
  }
}
