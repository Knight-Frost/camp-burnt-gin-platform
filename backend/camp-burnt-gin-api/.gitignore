# ==========================================================
# Logs & Runtime Files
# ==========================================================
*.log                        # Application and debug logs
.phpunit.result.cache        # PHPUnit cached test results
.phpunit.cache/              # PHPUnit internal cache directory


# ==========================================================
# OS / Editor / IDE Files
# ==========================================================
.DS_Store                    # macOS Finder metadata
Thumbs.db                    # Windows Explorer metadata

.vscode/                     # VS Code settings (anywhere in repo)
.idea/                       # JetBrains IDE settings
.fleet/                      # JetBrains Fleet
.zed/                        # Zed editor
.nova/                       # Nova editor


# ==========================================================
# Environment & Secrets (CRITICAL)
# ==========================================================
.env                         # Local environment variables (contains secrets)
.env.*                       # Any environment variants (production, staging, backups)
auth.json                    # Composer authentication tokens


# ==========================================================
# Dependency Directories
# ==========================================================
vendor/                      # PHP Composer dependencies (rebuildable)
node_modules/                # Node dependencies (rebuildable)


# ==========================================================
# Build & Compiled Assets
# ==========================================================
public/build/                # Frontend compiled assets
public/hot                   # Vite hot reload file
public/storage               # Laravel storage symlink


# ==========================================================
# Storage & Encryption Artifacts
# ==========================================================
storage/*.key                # Encryption keys (VERY sensitive)
storage/pail                 # Runtime storage artifacts


# ==========================================================
# Laravel / Vagrant / Local VM
# ==========================================================
Homestead.json               # Local Homestead configuration
Homestead.yaml               # Local Homestead configuration


# ==========================================================
# Temporary / Miscellaneous
# ==========================================================
*.swp                        # Vim swap files
*.tmp                        # Temporary files

backend/camp-burnt-gin-api/vendor/
# PHPUnit cache
.phpunit.result.cache
.phpunit.cache/
