APP_NAME="Camp Burnt Gin API"
APP_ENV=local
APP_KEY=
# PRODUCTION: APP_DEBUG must be false
APP_DEBUG=false
APP_URL=https://api.campburntgin.org

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=14
# HIPAA: token expiry ≤ 30 min for PHI-bearing sessions
SANCTUM_EXPIRATION=30
# PRODUCTION: set to comma-separated list of your frontend domain(s)
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:5174
AUTH_PASSWORD_TIMEOUT=900
PAGINATION_PER_PAGE=15

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# PRODUCTION: use 'warning' or 'error'; never 'debug'
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=camp_burnt_gin
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
# HIPAA: keep short; 30 min recommended
SESSION_LIFETIME=30
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SAME_SITE=strict
# PRODUCTION: must be true when serving over HTTPS
SESSION_SECURE_COOKIE=false

# CORS: comma-separated list of allowed frontend origins.
# PRODUCTION example: CORS_ALLOWED_ORIGINS=https://app.campburntgin.org
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@campburntgin.org"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
