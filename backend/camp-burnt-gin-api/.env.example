APP_NAME="Camp Burnt Gin API"
APP_ENV=local
APP_KEY=
# PRODUCTION: APP_DEBUG must be false
APP_DEBUG=false

# Document compliance strict mode.
# false → runs "document missing?" only; skips expired / unverified / incomplete.
#         Use in dev and staging to exercise submission flows against seed data.
# true  → full enforcement (required for production).
# Production deploys force this ON regardless of the value here.
APP_COMPLIANCE_CHECKS=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=14
# Token absolute maximum lifetime (minutes).
# The frontend useIdleTimeout hook enforces HIPAA inactivity logout (60 min) —
# this value is the hard upper bound for any session, active or idle.
# 480 = 8 hours (one full workday).
SANCTUM_EXPIRATION=480
# PRODUCTION: set to comma-separated list of your frontend domain(s)
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:5174
AUTH_PASSWORD_TIMEOUT=900
PAGINATION_PER_PAGE=15

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# PRODUCTION: use 'warning' or 'error'; never 'debug'
LOG_LEVEL=info

DB_CONNECTION=mysql
# Local: 127.0.0.1 | Docker: overridden to 'mysql' by docker-compose
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=camp_burnt_gin
# Local (Homebrew/Linux): root with no password is the default fresh-install setup.
# Docker: docker-compose connects as root; leave DB_PASSWORD blank here and
#         docker-compose will use 'password' as the MySQL root password automatically.
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
# HIPAA: keep short; 30 min recommended
SESSION_LIFETIME=30
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SAME_SITE=strict
# Set to false ONLY for local HTTP development (not production)
SESSION_SECURE_COOKIE=true

# CORS: comma-separated list of allowed frontend origins.
# PRODUCTION example: CORS_ALLOWED_ORIGINS=https://app.campburntgin.org
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
# Local: 127.0.0.1 | Docker: overridden to 'redis' by docker-compose
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Gmail SMTP (development / low-volume) ---
# Requires a Google App Password: Google Account → Security → App passwords
# PRODUCTION: switch to Mailgun or another transactional provider (higher limits, HIPAA BAA)
MAIL_MAILER=smtp
MAIL_SCHEME=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-gmail-account@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="your-gmail-account@gmail.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Mailgun (production recommended) ---
# MAIL_MAILER=mailgun
# MAILGUN_DOMAIN=your-mailgun-domain.com
# MAILGUN_SECRET=your-mailgun-api-key
# MAILGUN_ENDPOINT=api.mailgun.net
# MAIL_FROM_ADDRESS="noreply@campburntgin.org"
# MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- Seeding ---
# Controls which dataset php artisan migrate:fresh --seed loads.
# demo        → small polished dataset (default, good starting point)
# development → full simulation (~76 campers, all statuses, edge cases)
# minimal     → system config + super admin only (production bootstrap)
SEED_MODE=demo

# Super admin bootstrap account.
# ADMIN_BOOTSTRAP_EMAIL defaults to admin@campburntgin.org if unset.
# ADMIN_BOOTSTRAP_PASSWORD: set this before seeding; if unset a random password
# is generated and printed once to the console.
# PRODUCTION: always set this explicitly and rotate after first login.
ADMIN_BOOTSTRAP_EMAIL=admin@campburntgin.org
ADMIN_BOOTSTRAP_PASSWORD=

# --- Google OAuth ---
# Create credentials at: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI must match GOOGLE_REDIRECT_URI exactly.
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI="${APP_URL}/api/auth/google/callback"
